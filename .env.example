# =====================================================
# GEO 사이트 자동 생성기 - 환경 변수 설정 파일
# =====================================================
# 이 파일을 복사하여 .env.local 파일을 만드세요:
#   cp .env.example .env.local
# 그 후 아래 값들을 실제 값으로 교체하세요.
# =====================================================

# [필수] Claude AI API 키
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [필수] Firecrawl API 키
# 발급: https://www.firecrawl.dev/ (무료 500 크레딧 제공)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# [필수] 크롤링할 기존 사이트 URL
# 예시: https://www.example.com
TARGET_URL=https://your-existing-site.com
